{% extends "base.html.twig" %}
{%  block title %}{{ parent() }} - Liste des derniers articles {% endblock %}
{% block body %}
    <h1>Voici les 20 derniers articles :</h1>

    <table class="table">
        <thead>
        <tr>
            <th scope="col">Voir</th>
            <th scope="col">Titre</th>
            <th scope="col">Date de Publication</th>
            <th scope="col">Auteur</th>
        </tr>
        </thead>
        <tbody>
        {% for article in articles %}
            <tr>
                <td><a href="/?controller=AdminArticle&action=show&param={{ article.Id }}"><i class="bi bi-eye"></i></a></td>
                <td>{{ article.Titre }}</td>
                <td>{{ article.DatePublication|date('d/m/Y') }}</td>
                <td>{{ article.Auteur }}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

{% endblock %}
